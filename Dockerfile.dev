# Development Dockerfile with hot reload
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy Prisma schema
COPY prisma ./prisma

# Generate Prisma client
RUN npx prisma generate

# Copy source (will be overridden by volume mount)
COPY . .

# Expose port
EXPOSE 3001

# Start with hot reload
CMD ["npm", "run", "dev"]
