# Server
NODE_ENV=development
PORT=3001

# Database (for local development without Docker)
#DATABASE_URL="postgresql://staffsync:staffsync_dev_123@localhost:5432/staffsync?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# SMTP (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# ===========================================
# Stripe Payment Integration
# ===========================================

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret (get from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard > Products)
# Standard Plan: £500/month
STRIPE_STANDARD_MONTHLY_PRICE_ID=price_standard_monthly
STRIPE_STANDARD_YEARLY_PRICE_ID=price_standard_yearly

# Enterprise Plan (custom pricing - placeholder)
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_enterprise_custom
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_enterprise_custom

# Frontend URL (for Stripe redirects)
FRONTEND_URL=http://localhost:3000

# ===========================================
# Docker Configuration
# ===========================================

# PostgreSQL (used by docker-compose)
POSTGRES_USER=staffsync
POSTGRES_PASSWORD=staffsync_dev_123
POSTGRES_DB=staffsync

# pgAdmin (optional web UI for PostgreSQL)
PGADMIN_EMAIL=admin@staffsync.com
PGADMIN_PASSWORD=admin123

# ===========================================
# Connection Examples
# ===========================================

# Local Docker:
# DATABASE_URL="postgresql://staffsync:staffsync_dev_123@localhost:5432/staffsync?schema=public"

# Inside Docker container (use service name):
# DATABASE_URL="postgresql://staffsync:staffsync_dev_123@postgres:5432/staffsync?schema=public"

# Hosted PostgreSQL (Supabase, Neon, Railway, etc.):
 DATABASE_URL="postgresql://staffsync_97y9_user:C4kD8ioJWWGXslW7TArnw6ro0gtEyQLz@dpg-d6maih7kijhs73frn22g-a.oregon-postgres.render.com/staffsync_97y9"
