# Server
NODE_ENV=development
PORT=3001

# Database (for local development without Docker)
#DATABASE_URL="postgresql://staffsync:staffsync_dev_123@localhost:5432/staffsync?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# SMTP (SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com

# Twilio (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# ===========================================
# Stripe Payment Integration
# ===========================================

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Webhook Secret (get from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Free Trial Duration (days)
FREE_TRIAL_DAYS=180

# ===========================================
# Per-Worker Pricing Model
# ===========================================
# Pricing is in PENCE (250 = £2.50)
# Create products in Stripe Dashboard with "Per unit" pricing model

# Starter Plan (1-10 workers)
STRIPE_STARTER_MONTHLY_PER_WORKER=250      # £2.50 per worker/month
STRIPE_STARTER_YEARLY_PER_WORKER=200       # £2.00 per worker/month (billed annually)
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxx

# Professional Plan (11-50 workers)
STRIPE_PROFESSIONAL_MONTHLY_PER_WORKER=350 # £3.50 per worker/month
STRIPE_PROFESSIONAL_YEARLY_PER_WORKER=300  # £3.00 per worker/month (billed annually)
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxxxxxxxxxxx

# Business Plan (51-200 workers)
STRIPE_BUSINESS_MONTHLY_PER_WORKER=450     # £4.50 per worker/month
STRIPE_BUSINESS_YEARLY_PER_WORKER=400      # £4.00 per worker/month (billed annually)
STRIPE_BUSINESS_PRICE_ID=price_xxxxxxxxxxxxx

# Enterprise Plan (200+ workers - custom pricing)
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxx

# Frontend URL (for Stripe redirects)
FRONTEND_URL=http://localhost:3000

# ===========================================
# Docker Configuration
# ===========================================

# PostgreSQL (used by docker-compose)
POSTGRES_USER=staffsync
POSTGRES_PASSWORD=staffsync_dev_123
POSTGRES_DB=staffsync

# pgAdmin (optional web UI for PostgreSQL)
PGADMIN_EMAIL=admin@staffsync.com
PGADMIN_PASSWORD=admin123

# ===========================================
# Connection Examples
# ===========================================

# Local Docker:
# DATABASE_URL="postgresql://staffsync:staffsync_dev_123@localhost:5432/staffsync?schema=public"

# Inside Docker container (use service name):
# DATABASE_URL="postgresql://staffsync:staffsync_dev_123@postgres:5432/staffsync?schema=public"

